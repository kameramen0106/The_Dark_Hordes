msgstr ""

#. [scenario]: id=10_Return_to_the_Northlands
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:5
msgid "Return to the Northlands"
msgstr ""

#. [side]
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:44
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:49
msgid "team_name^Tanar"
msgstr ""

#. [side]: type=Orcish Warlord, id=Vrork
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:77
msgid "Vrork"
msgstr ""

#. [event]
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:158
msgid "Kill all enemy units"
msgstr ""

#. [event]
#. [case]
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:159
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:161
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:422
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:220
msgid "Destruction of Gwiti Ha’atel"
msgstr ""

#. [message]: speaker=Vrork
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:179
msgid "Which cave-orc dares trespass on my land?"
msgstr ""

#. [message]: speaker=Tanar
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:184
msgid "I am Tanar. My clan and I seek passage to the north, by force if need be."
msgstr ""

#. [message]: speaker=Vrork
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:189
msgid "I am the great Vrork! No weakling cave-orc will pass through my lands! Slay them, my grunts!"
msgstr ""

#. [message]: speaker=Tanar
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:194
msgid "My brethren, the enemy we have been yearning to fight has arrived!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:199
msgid "It seems I’ll have dead orcs marching with me as well as living ones. He, he he..."
msgstr ""

#. [message]: speaker=Vrork
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:255
msgid "No cave-orc can kill me! I am the might Vro..."
msgstr ""

#. [message]: speaker=second_unit
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:270
msgid "I didn’t know surface orcs were this fragile."
msgstr ""

#. [message]: speaker=second_unit
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:291
msgid "I am no orc!"
msgstr ""

#. [message]
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:318
msgid "Those weaklings needed help from the undead to kill our chief! No surrender! Kill them all!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:322
msgid "Yes! Stay and fight! Give me more corpses to work with!"
msgstr ""

#. [message]
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:366
msgid "We are getting slaughtered! Run for your lives!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/10_Return_to_the_Northlands.cfg:371
msgid "Let them run! All shall fear me!"
msgstr ""

#. [scenario]: id=11_An_Orcish_Coup
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:5
msgid "An Orcish Coup"
msgstr ""

#. [side]: type=Orcish Sovereign, id=Kogran
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:79
msgid "Kogran"
msgstr ""

#. [side]: type=Orcish Sovereign, id=Eradush
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:105
msgid "Eradush"
msgstr ""

#. [side]: type=Orcish Sovereign, id=Prirag
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:131
msgid "Prirag"
msgstr ""

#. [event]
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:160
msgid "Complete the Skull of Morgorath"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:193
msgid "One of those three warlords has the skull, though I cannot tell which."
msgstr ""

#. [message]: speaker=Tanar
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:198
msgid "It is a large host they have gathered here. It would be wise to avoid fighting them head on, even if they haven’t united under one banner."
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:203
msgid "I may have a way to assassinate the leaders, but we will need to draw away their forces..."
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:222
msgid "Hello brother, you will be serving as ingredients today."
msgstr ""

#. [message]: speaker=narrator
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:227
msgid "Some time passes..."
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:235
msgid "This potion is powerful as it is going to get. Let’s see the effects."
msgstr ""

#. [hides]: id=invisible
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:270
msgid "invisible"
msgstr ""

#. [hides]: id=invisible
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:271
msgid ""
"The unit is invisible.\n"
"\n"
"Enemy units cannot see this unit, except if they have units next to it. Any enemy unit that first discovers this unit immediately loses all its remaining movement."
msgstr ""

#. [hides]: id=invisible
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:281
msgid "mostly invisible"
msgstr ""

#. [hides]: id=invisible
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:282
msgid ""
"The unit is invisible, except during the day.\n"
"\n"
"Enemy units can only see this unit during the day, or if they have units next to it. Any enemy unit that first discovers this unit immediately loses all its remaining movement."
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:317
msgid "This should ease the retrieval of the skull, but those chieftains will still be hard to get to."
msgstr ""

#. [message]: speaker=Tanar
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:322
msgid "I can distract the patrols, but my clan cannot fight off this horde alone. You must not delay."
msgstr ""

#. [message]: speaker=Nati Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:330
msgid "Aaaaaaiiiiiiiiigh!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:335
msgid "Dear brother, would you be so kind to explain to me why I am visible?"
msgstr ""

#. [message]: speaker=Nati Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:340
msgid "The light ... weakens me, the magic ... should resume ... at dusk."
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:345
msgid "Perhaps you aren’t as powerful as you had thought. A lich’s eyes should keep me invisible even during the day."
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:357
msgid "Go back to the shades, you incompetent fool!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:369
msgid "Noooo! Not so close to the skull!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:403
msgid "This chieftain does not have the skull!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:410
msgid "Finally! The other half! Let us see what it can do!"
msgstr ""

#. [case]
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:421
msgid "Kill the last orcish leader"
msgstr ""

#. [message]: role=new_leader
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:456
msgid "We surrender, great chief! The horde is yours to command."
msgstr ""

#. [message]: speaker=Tanar
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:461
msgid "Tend to the wounded and gather your equipment. We have a campaign to plan."
msgstr ""

#. [message]
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:486
msgid "Sound the retreat! But know that I will come for your skull, foul necromancer!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/11_An_Orcish_Coup.cfg:494
msgid "The skull is still out of my reach!"
msgstr ""

#. [scenario]: id=12_Assault_on_Alduin
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:6
msgid "Assault on Alduin"
msgstr ""

#. [side]: type=Great Mage, id=Laellyn
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:77
msgid "Laellyn"
msgstr ""

#. [side]: type=Mage of Light, id=Menvan
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:116
msgid "Menvan"
msgstr ""

#. [side]: type=Arch Mage, id=Caroran
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:141
msgid "Caroran"
msgstr ""

#. [side]: type=Arch Mage, id=Aethacyn
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:166
msgid "Aethacyn"
msgstr ""

#. [event]
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:219
msgid "Kill all magi above level 1"
msgstr ""

#. [message]: speaker=narrator
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:232
msgid "After enjoying the trip by ship, Gwiti himself led the skeletons to invade the coast of Alduin. The area was covered with magical wards, but they had already been weathered by the years and did not impede his path."
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:238
msgid "The magic of my artifacts is still effective in this battle..."
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:245
msgid "Now our enemies will not be aware of our presence until we strike first. As soon as the battle begins, my disciple Arkal-Thil will reinforce us from the east. We must surely destroy this den of magi."
msgstr ""

#. [message]: role=discoverer
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:264
msgid "Attacked by the undead! Protect the Council!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:269
msgid "They finally realized the danger they were facing, but no longer too late."
msgstr ""

#. [unit]: type=Necromancer, id=Arkal-Thil
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:316
msgid "Arkal-Thil"
msgstr ""

#. [message]: speaker=Arkal-Thil
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:343
msgid "Master! We finally arrived!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:348
msgid "Now is the time to eradicate all magi. We must search the whole island and wipe them out."
msgstr ""

#. [message]: speaker=Arkal-Thil
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:353
msgid "Understood."
msgstr ""

#. [message]: speaker=unit
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:376
msgid "Unbelievable! Have we been defeated by them?!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:386
msgid "Kill every last one of them, and their blood will be food for my purpose!"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:412
msgid "Now all the fools who stand in my way are gone!"
msgstr ""

#. [message]: speaker=second_unit
#: The_Dark_Hordes/scenarios/12_Assault_on_Alduin.cfg:457
msgid "There is no sense in you poor beings resisting me!"
msgstr ""

#. [unit_type]: id=Dark Acolyte, race=human
#: The_Dark_Hordes/units/Dark_Acolyte.cfg:5
msgid "Dark Acolyte"
msgstr ""

#. [unit_type]: id=Dark Acolyte, race=human
#: The_Dark_Hordes/units/Dark_Acolyte.cfg:20
msgid "He is already tainted with evil, forbidden magic, but his powers remain unfinished. Still, he will be an object of hatred and fear for many. But he has no hesitation about it; in fact, he feels strangely exalted."
msgstr ""

#. [unit_type]: id=Dark Spirit, race=undead
#: The_Dark_Hordes/units/Dark_Spirit.cfg:5
msgid "Dark Spirit"
msgstr ""

#. [unit_type]: id=Dark Spirit, race=undead
#: The_Dark_Hordes/units/Dark_Spirit.cfg:18
msgid "Dark Spirits are messengers and bearers of tidings from the realm of the dead, and a force of dread in this world. Luckily, they have rarely been seen in Wesnoth."
msgstr ""

#. [unit_type]: id=Deathmaster, race=human
#: The_Dark_Hordes/units/Deathmaster.cfg:5
msgid "Deathmaster"
msgstr ""

#. [unit_type]: id=Deathmaster, race=human
#: The_Dark_Hordes/units/Deathmaster.cfg:21
msgid "His wanderings on a dark path have given him power normally not granted to mortals, but with a terrible cost: the undead that he gave his soul to are gradually claiming his mortal shell too, and with time, he will be a true undead and a terror to all that lives."
msgstr ""

#. [unit_type]: id=Demilich, race=undead
#: The_Dark_Hordes/units/Demilich.cfg:5
msgid "Demilich"
msgstr ""

#. [unit_type]: id=Demilich, race=undead
#: The_Dark_Hordes/units/Demilich.cfg:25
msgid "After too much time dabbling with forbidden magics and dark arts, these magi have begun to pay a heavy price. Demiliches have started losing their bodies, becoming undead themselves. With time, they may become fully undead, and feared by all alike."
msgstr ""

#. [unit_type]: id=Dread Lich, race=undead
#: The_Dark_Hordes/units/Dread_Lich.cfg:5
msgid "Dread Lich"
msgstr ""

#. [unit_type]: id=Dread Lich, race=undead
#: The_Dark_Hordes/units/Dread_Lich.cfg:26
msgid "At long last, Ha’atel has paid the ultimate sacrifice for the dark arts into which he has delved, and has, himself, entered into undeath. At the apex of his power, he has become a lich, a waking embodiment of dread. He has, beyond any doubt, passed the point of no return, and his power and immortality will have to provide consolation for what he has lost in his quest to achieve them."
msgstr ""

#. [unit_type]: id=Initiate, race=human
#: The_Dark_Hordes/units/Initiate.cfg:5
msgid "Initiate"
msgstr ""

#. [unit_type]: id=Initiate, race=human
#: The_Dark_Hordes/units/Initiate.cfg:19
msgid "Dabbling in the Death Magic, this young Ha’atel’s lust for power has weakened him to the point where he is too weak to attack in regular combat."
msgstr ""

#: The_Dark_Hordes/utils/character-defines.cfg:5
msgid "Gwiti Ha’atel"
msgstr ""

#: The_Dark_Hordes/utils/character-defines.cfg:14
msgid "Leganoth"
msgstr ""

#: The_Dark_Hordes/utils/character-defines.cfg:24
#: The_Dark_Hordes/utils/character-defines.cfg:42
msgid "Tanar"
msgstr ""

#. [message]: speaker=Gwiti Ha'atel
#: The_Dark_Hordes/utils/death-utils.cfg:49
msgid "Morgorath! Show me your power!"
msgstr ""

#. [object]: id={ID}
#: The_Dark_Hordes/utils/items.cfg:28
msgid "Ice Potion"
msgstr ""

#. [object]: id={ID}
#: The_Dark_Hordes/utils/items.cfg:31
msgid "This potion contains a strange fluid designed to imbue a weapon with the power of cold."
msgstr ""

#. [object]: id={ID}
#: The_Dark_Hordes/utils/items.cfg:32
msgid "Only a skeletal unit may acquire this dreaded power!"
msgstr ""

#. [message]: speaker=narrator
#: The_Dark_Hordes/utils/scenario-utils.cfg:32
msgid "You retrieve $temp_gold_retrieval_amount pieces of gold."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:9
msgid "At a great battle at the Stone of Erzen, the brothers Gwiti and Nati Ha’atel showed their skills for the first time: Thinking that their side was losing the battle, they called upon the corpses of former enemies to rise again and fight on their side."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:14
msgid "However, not only was this forbidden, but rash as well. The cavalry meant to come as reinforcements instead clashed with the undead legions, and so the battle was lost where it would have been won had it not been for these two dark sorcerers."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:19
msgid "The Ha’atel brothers fled. Immediately upon their return, they were clapped in irons, marched onto a ship with no rudder, and sent off to drown in the sea, for the Wesnothians feared that their corpses might only rise again."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:25
msgid "But Fate intervened. The ship was beset by a sudden storm and disintegrated, separating the brothers and washing them both ashore. This was the beginning of the Rise of the Dark Hordes."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:37
msgid "As Gwiti explored the unknown land, he ran into his brother."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:49
msgid "Still wandering the unknown land, Gwiti entered lands of the Orcs."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:53
msgid "They all bore skull-topped banners. But one of these skulls was special..."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:65
msgid "Furious at the Skull’s lack of power, Gwiti decided to seize a different artifact, the Book of Crelanu."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:77
msgid "According to the journal Gwiti recovered, after the death of Delfador the Great, the tradition was started to entrust the Book with the King’s closest advisor."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:81
msgid "This turned out to be a costly mistake, sparking the greatest undead invasion Wesnoth had ever seen."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:85
msgid "After this, no mage dared take guardianship of the Book. Instead, they decided to hide Crelanu’s work where none would find it, while spreading rumors that it was guarded in the Tower of Kaleon."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:89
msgid "Five centuries later, Gwiti retraced their steps, which led him to a war-torn valley."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:105
msgid "Gwiti and Tanar rushed into the maze of twisting little passages, quickly leaving the humans behind. But not much later, they ran into dwarves..."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:117
msgid "Crossing the pool did not take long and soon the orcs and undead marched on through the damp cave, into the mountain. While the orcs shivered in the magical air, Gwiti spent some time reading the Tome."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:129
msgid "The orcs and undead easily defended the cave stronghold and when the water subsided, the nagas were driven off or slain, their magical artifact exhausted."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:139
msgid "Months later, Gwiti finished studying the Tome of Crelanu and departed for where he believed the other half of Morgorath’s skull to be. The orcs, restless without an enemy to fight, eagerly followed."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:151
msgid "Gwiti’s research directed him north, further into the orcish lands. Eventually, he could sense the presence of the skull’s other half. The feeling led him to what appeared to be an orcish capital."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:163
msgid "Tanar decided to use the death of the would-be Great Chiefs to subject the local tribes to his own rule. Plans to jointly invade Wesnoth were discussed."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:167
msgid "Gwiti knew that as long as paladins and magi roamed the land, any invasion would be severely hindered. So he decided to strike at the source of his problems: Alduin."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:179
msgid "With the magi out of the way, Gwiti was ready to begin his invasion, starting at the city of Aldril."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:191
msgid "Unknown to Gwiti, several magi present on Alduin had survived his attack. Faced with a danger beyond their own ability, they contacted outside help, the slayer of the Necromancer-Emperor."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:211
msgid "Gwiti survived being turned on by the orcs and managed to escape eastwards."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:215
msgid "The Northern Alliance had sent military aid and with two armies hunting for him, Gwiti was trapped in the Estmarks."
msgstr ""

#. [part]
#: The_Dark_Hordes/utils/storytxt.cfg:219
msgid "He spent months evading patrols while trying to build his strength back up. Eventually, he was hunted down by a rather familiar elf."
msgstr ""

#. [message]: speaker=Tanar
#: The_Dark_Hordes/utils/tanar-utils.cfg:12
msgid "Avenge me, my brethren! We have been betrayed!"
msgstr ""

#. [message]: role=second
#: The_Dark_Hordes/utils/tanar-utils.cfg:38
msgid "I never liked those undead anyway!"
msgstr ""

#. [message]
#: The_Dark_Hordes/utils/tanar-utils.cfg:86
msgid "Run for your lives!!"
msgstr ""

#. [message]: role=second
#: The_Dark_Hordes/utils/tanar-utils.cfg:101
#: The_Dark_Hordes/utils/tanar-utils.cfg:118
msgid "This looks like a good moment for a tactical withdrawal."
msgstr ""

